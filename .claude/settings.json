{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(renga --version)",
      "Bash(renga --help)",
      "Bash(renga --layout:*)",
      "Bash(renga mcp install:*)",
      "Bash(renga mcp uninstall:*)",
      "Bash(renga mcp status:*)",
      "Bash(renga mcp --help)",
      "mcp__renga-peers__set_summary",
      "mcp__renga-peers__list_peers",
      "mcp__renga-peers__send_message",
      "mcp__renga-peers__check_messages",
      "mcp__renga-peers__list_panes",
      "mcp__renga-peers__spawn_pane",
      "mcp__renga-peers__close_pane",
      "mcp__renga-peers__focus_pane",
      "mcp__renga-peers__new_tab",
      "mcp__renga-peers__inspect_pane",
      "mcp__renga-peers__poll_events",
      "mcp__renga-peers__send_keys",
      "mcp__renga-peers__spawn_claude_pane",
      "mcp__renga-peers__set_pane_identity"
    ],
    "deny": [
      "Bash(git commit --no-verify*)",
      "Bash(git commit * --no-verify*)",
      "Bash(git -C * commit --no-verify*)",
      "Bash(git -C * commit * --no-verify*)",
      "Bash(git push --no-verify*)",
      "Bash(git push * --no-verify*)",
      "Bash(git -C * push --no-verify*)",
      "Bash(git -C * push * --no-verify*)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git -C * push --force*)",
      "Bash(git -C * push * --force*)",
      "Bash(git push -f*)",
      "Bash(git push * -f*)",
      "Bash(git -C * push -f*)",
      "Bash(git -C * push * -f*)",
      "Bash(git reset --hard*)",
      "Bash(git reset * --hard*)",
      "Bash(git -C * reset --hard*)",
      "Bash(git -C * reset * --hard*)",
      "Bash(git branch -D*)",
      "Bash(git branch * -D*)",
      "Bash(git -C * branch -D*)",
      "Bash(git -C * branch * -D*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.hooks/block-no-verify.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.hooks/block-dangerous-git.sh\""
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "**/credentials*",
        "**/*.pem",
        "~/.config/gh/hosts.yml"
      ],
      "denyWrite": [
        "~/.claude/settings.json"
      ]
    }
  }
}
