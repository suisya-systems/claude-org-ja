# Session state (machine-local, not shared)
.state/*
!.state/.gitkeep
!.state/workers/
.state/workers/*
!.state/workers/.gitkeep

# Knowledge: operator-private assets are machine-local, not shared (Issue #755).
# - Raw learnings (knowledge/raw/) are machine-local scratch, never committed.
# - The skill-candidate queue's real entries live in the .local.md sibling; the
#   tracked knowledge/skill-candidates.md carries the entry-FORMAT definition
#   only (its entry list is always empty).
# - Operator-private curated notes use the .local.md suffix; the shared
#   operational curated docs (knowledge/curated/*.md without .local) stay tracked.
# See docs/contracts/knowledge-curation-contract.md §3.4.
knowledge/raw/*
!knowledge/raw/.gitkeep
knowledge/skill-candidates.local.md
knowledge/curated/*.local.md

# Dashboard generated data (replaced by live server)
dashboard/data.json
.state/dashboard.pid

# Dispatcher state (machine-local, not shared)
.dispatcher/.state/

# Curator local config
.curator/.claude/

# Claude Code local config
.claude/settings.local.json
.claude/settings.local.override.json
.claude/settings.local.json.bak.*
CLAUDE.local.md

# Dispatcher local config (symmetrical with .curator/.claude/)
.dispatcher/.claude/

# Internal docs (not for public consumption)
docs/internal/
docs/github-issues/

# Python build artifacts
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# OS metadata
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*
.claude/scheduled_tasks.lock

# M4 (Issue #267): journal.jsonl decommissioned — events table is the SoT.
# Local files lingering from pre-M4 runs are no longer authoritative.
.state/journal.jsonl

# Local Python venv (Secretary main working tree only)
.venv/

# Ad-hoc scratch / log artifacts
tmp/
err.log

# Dispatcher pane snapshot scratch (machine-local)
.dispatcher/panes-snapshot-tmp.json
