          "path": ".config/gh/hosts.yml",
          "suppressOnSymlinkEscape": true,
          "layer2Fallback": "Read(~/.config/gh/hosts.yml)"
        },
        "reason": "realpath escapes sandbox read roots",
        "realpath": "/H/.config/gh/hosts.yml",
        "sandbox_read_roots": [
          "/home/u/co/.curator",
          "/home/u/co/knowledge"
        ]
      },
      {
        "layer": "sandbox.filesystem.denyRead",
