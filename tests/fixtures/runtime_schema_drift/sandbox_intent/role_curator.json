    "role": "curator",
    "role_kind": "org",
    "worker_dir": "/home/u/co/.curator",
    "claude_org_path": "/home/u/co",
    "home_dir": "/H",
    "wsl_detected": false,
    "realpath_map": [],
    "schema_source": "shipped"
  },
  "expected_explain": {
    "enabled": true,
